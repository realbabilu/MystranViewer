  SPC = 1
  LOAD = 1
  DISPLACEMENT(SORT1,REAL) = ALL
  FORCE(SORT1,REAL) = ALL
  STRESS(CORNER,CENTER,PRINT,POST) = ALL
SUBCASE 2
